{
  "name": "@smritiflow/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "smritiflow": "bin/smritiflow.js",
    "sf": "bin/smritiflow.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "devDependencies": {
    "esbuild": "^0.27.4"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "rm -rf dist && esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/index.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
