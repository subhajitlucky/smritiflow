    "vitest": "^4.1.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.4",
    "picocolors": "^1.1.1",
    "simple-git": "^3.33.0",
    "zod": "^4.3.6"
  }
}
