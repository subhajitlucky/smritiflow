{
  "name": "smritiflow",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter ./apps/cli dev",
    "lint": "pnpm typecheck",
